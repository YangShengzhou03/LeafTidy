{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "饔사씜壤믤。",
  "version": "1.0.0",
  "identifier": "com.leaftidy.desktop",
  "build": {
    "beforeDevCommand": "npm run server",
    "devUrl": "http://localhost:8080",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "饔사씜壤믤。",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "maxWidth": 99999,
        "maxHeight": 99999,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "visible": true,
        "focus": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "geodata/*"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": {
        "language": "zh-CN"
      },
      "nsis": {
        "languages": ["SimpChinese"]
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
